# Local database and queue. Production Cloud Run uses DATA_BACKEND=firestore.
DATA_BACKEND="postgres"
DATABASE_URL="postgresql://safa:safa@localhost:5432/safa?schema=public"
REDIS_URL="redis://localhost:6379"
QUEUE_MODE="redis"
APP_SECRET_KEY="change-this-to-a-random-64-character-local-secret"
SAFA_SESSION_SECRET="change-this-to-a-different-random-64-character-session-secret"
SAFA_ADMIN_USERNAME="sarper"
# Use either SAFA_ADMIN_PASSWORD or SAFA_ADMIN_PASSWORD_HASH in production.
SAFA_ADMIN_PASSWORD=""
SAFA_ADMIN_PASSWORD_HASH=""
# Keep true in Cloud Run by leaving NODE_ENV=production; local HTTP dev can leave this unset.
SAFA_COOKIE_SECURE=""

# App ports
API_PORT=4000
CORS_ORIGIN="http://localhost:3000"
ENABLE_PRIVATE_NETWORK_CORS=""
API_PROXY_ORIGIN="http://localhost:4000"
# Optional. Leave empty to let the web app use its /api proxy.
NEXT_PUBLIC_API_BASE_URL=""

# Keep true until Trendyol and GIB live credentials are configured.
USE_MOCK_INTEGRATIONS=true
AUTO_SYNC_ENABLED=false
AUTO_SYNC_INTERVAL_MS=900000
STORAGE_DIR="./storage"

# Trendyol Partner credentials
TRENDYOL_BASE_URL="https://apigw.trendyol.com"
TRENDYOL_SELLER_ID=""
TRENDYOL_API_KEY=""
TRENDYOL_API_SECRET=""
TRENDYOL_USER_AGENT="SAFA local e-arsiv integration"
TRENDYOL_STOREFRONT_CODE="TR"
TRENDYOL_LOOKBACK_DAYS=14

# Invoice provider
# Supported: mock, gib-direct.
# gib-direct is the official "Bilgi Islem Sisteminin Entegrasyonu" route. It requires
# GIB test approval, live authorization, and certificate/signature setup before it can
# issue real invoices.
INVOICE_PROVIDER="mock"
GIB_EARSIV_ENV="test"
GIB_EARSIV_WSDL_URL="https://test.efatura.gov.tr/earsiv/services/EArsivWsPort?wsdl"
GIB_EARSIV_SERVICE_URL=""
GIB_EARSIV_TAX_ID=""
GIB_EARSIV_CERT_PATH=""
GIB_EARSIV_CERT_PASSWORD=""
GIB_EARSIV_SENDER_ALIAS=""
GIB_EARSIV_UNIT_CODE="C62"
GIB_EARSIV_DEFAULT_BUYER_TCKN="11111111111"
