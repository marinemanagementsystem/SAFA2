{
  "name": "@safa/api",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "set -a; [ -f ../../.env ] && . ../../.env; set +a; tsx watch src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "set -a; [ -f ../../.env ] && . ../../.env; set +a; node dist/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "db:generate": "set -a; [ -f ../../.env ] && . ../../.env; set +a; prisma generate",
    "db:migrate": "set -a; [ -f ../../.env ] && . ../../.env; set +a; prisma migrate deploy",
    "db:studio": "set -a; [ -f ../../.env ] && . ../../.env; set +a; prisma studio",
    "migrate:firestore": "set -a; [ -f ../../.env ] && . ../../.env; set +a; tsx ../../scripts/migrate-cloud-sql-to-firestore.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.9",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.9",
    "@nestjs/platform-express": "^11.1.9",
    "@nestjs/schedule": "^6.0.1",
    "@nestjs/swagger": "^11.2.3",
    "@prisma/client": "^6.19.0",
    "archiver": "^6.0.2",
    "axios": "^1.13.2",
    "bullmq": "^5.64.1",
    "exceljs": "^4.4.0",
    "firebase-admin": "^13.9.0",
    "form-data": "^4.0.5",
    "ioredis": "^5.8.2",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/express": "^5.0.5",
    "@types/node": "^24.10.1",
    "@types/qrcode": "^1.5.6",
    "prisma": "^6.19.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.13"
  }
}
