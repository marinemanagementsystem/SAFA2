generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum DraftStatus {
  NEEDS_REVIEW
  READY
  APPROVED
  ISSUING
  PORTAL_DRAFTED
  ISSUED
  ERROR
}

enum InvoiceStatus {
  ISSUED
  TRENDYOL_SENT
  TRENDYOL_SEND_FAILED
}

enum JobStatus {
  PENDING
  PROCESSING
  SUCCESS
  FAILED
}

enum ExternalInvoiceSource {
  GIB_PORTAL
  TRENDYOL
  MANUAL
}

enum MarketplaceProvider {
  HEPSIBURADA
}

enum OrderSource {
  TRENDYOL
  HEPSIBURADA
}

model Setting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

model Product {
  id          String   @id @default(cuid())
  name        String
  barcode     String?  @unique
  merchantSku String   @unique
  brand       String
  categoryName String
  vatRate     Int      @default(20)
  priceCents  Int
  stock       Int      @default(0)
  dispatchTime Int     @default(2)
  description String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  marketplaceListings MarketplaceListing[]

  @@index([active])
  @@index([merchantSku])
}

model MarketplaceListing {
  id             String              @id @default(cuid())
  provider       MarketplaceProvider
  productId      String
  product        Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  hbSku          String?
  merchantSku    String
  priceCents     Int
  stock          Int                 @default(0)
  dispatchTime   Int                 @default(2)
  lastStatus     String?
  lastUploadedAt DateTime?
  lastTrackingId String?
  lastJobId      String?
  raw            Json?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@unique([provider, merchantSku])
  @@index([hbSku])
  @@index([lastTrackingId])
}

model Order {
  id                 String        @id @default(cuid())
  source             OrderSource   @default(TRENDYOL)
  shipmentPackageId  String        @unique
  orderNumber        String
  status             String
  customerName       String
  customerEmail      String?
  customerIdentifier String?
  invoiceAddress     Json
  raw                Json
  totalGrossCents    Int
  totalDiscountCents Int
  totalPayableCents  Int
  currency           String        @default("TRY")
  lastModifiedAt     DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  invoiceDraft       InvoiceDraft?
  externalInvoices   ExternalInvoice[]
  hepsiburadaOrderLines HepsiburadaOrderLine[]

  @@index([status])
  @@index([orderNumber])
  @@index([lastModifiedAt])
  @@index([source])
}

model InvoiceDraft {
  id           String    @id @default(cuid())
  orderId      String    @unique
  order        Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  documentType String    @default("E_ARCHIVE")
  status       DraftStatus
  validation   Json
  lines        Json
  totals       Json
  approvedAt   DateTime?
  portalDraftUuid       String?
  portalDraftNumber     String?
  portalDraftUploadedAt DateTime?
  portalDraftStatus     String?
  portalDraftResponse   Json?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  invoice      Invoice?

  @@index([status])
  @@index([portalDraftUuid])
  @@index([portalDraftUploadedAt])
}

model Invoice {
  id                String        @id @default(cuid())
  draftId           String        @unique
  draft             InvoiceDraft  @relation(fields: [draftId], references: [id], onDelete: Cascade)
  provider          String
  providerInvoiceId String
  invoiceNumber     String        @unique
  invoiceDate       DateTime
  status            InvoiceStatus
  pdfPath           String?
  pdfUrl            String?
  trendyolSentAt    DateTime?
  trendyolStatus    String?
  error             String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  publicTokens      PublicInvoiceToken[]

  @@index([status])
  @@index([invoiceDate])
}

model HepsiburadaOrderLine {
  id            String   @id @default(cuid())
  lineItemId    String   @unique
  orderNumber   String
  hbSku         String
  merchantSku   String?
  quantity      Int
  raw           Json
  packageNumber String?
  packageStatus String   @default("OPEN")
  linkedOrderId String?
  linkedOrder   Order?   @relation(fields: [linkedOrderId], references: [id], onDelete: SetNull)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([orderNumber])
  @@index([hbSku])
  @@index([merchantSku])
  @@index([packageNumber])
  @@index([packageStatus])
  @@index([linkedOrderId])
}

model PublicInvoiceToken {
  id            String   @id @default(cuid())
  tokenHash     String   @unique
  invoiceId     String
  invoice       Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  provider      String
  packageNumber String?
  expiresAt     DateTime
  usedAt        DateTime?
  createdAt     DateTime @default(now())

  @@index([invoiceId])
  @@index([expiresAt])
  @@index([provider])
}

model ExternalInvoice {
  id                String                @id @default(cuid())
  source            ExternalInvoiceSource
  externalKey       String
  invoiceNumber     String?
  invoiceDate       DateTime?
  buyerName         String?
  buyerIdentifier   String?
  orderNumber       String?
  shipmentPackageId String?
  totalPayableCents Int?
  currency          String                @default("TRY")
  status            String?
  pdfUrl            String?
  xmlUrl            String?
  raw               Json
  matchedOrderId    String?
  matchedOrder      Order?                @relation(fields: [matchedOrderId], references: [id], onDelete: SetNull)
  matchScore        Int                   @default(0)
  matchReason       String?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  @@unique([source, externalKey])
  @@index([invoiceNumber])
  @@index([invoiceDate])
  @@index([orderNumber])
  @@index([shipmentPackageId])
  @@index([matchedOrderId])
}

model IntegrationJob {
  id        String    @id @default(cuid())
  type      String
  target    String
  status    JobStatus
  attempts  Int       @default(0)
  lastError String?
  payload   Json?
  response  Json?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([status])
  @@index([type])
}

model AuditLog {
  id          String   @id @default(cuid())
  action      String
  subjectType String
  subjectId   String
  message     String
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([subjectType, subjectId])
  @@index([createdAt])
}
