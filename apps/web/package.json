{
  "name": "@safa/web",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "build:firebase": "FIREBASE_STATIC_EXPORT=true NEXT_PUBLIC_API_BASE_URL=/api next build",
    "build:motogrip": "FIREBASE_STATIC_EXPORT=true NEXT_PUBLIC_BASE_PATH=/dev/motogrip NEXT_PUBLIC_API_BASE_URL=/dev/motogrip/api NEXT_PUBLIC_SITE_URL=https://motogrip.com.tr/dev/motogrip next build",
    "start": "next start -p ${PORT:-3000}",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@safa/shared": "workspace:*",
    "firebase": "^12.13.0",
    "lucide-react": "^0.555.0",
    "next": "^16.2.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  }
}
