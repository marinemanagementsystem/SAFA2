{
  "name": "safa",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.28.2",
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "pnpm --parallel --filter @safa/api --filter @safa/web dev",
    "dev:api": "pnpm --filter @safa/api dev",
    "dev:web": "pnpm --filter @safa/web dev",
    "start:api": "pnpm --filter @safa/api start",
    "start:web": "pnpm --filter @safa/web start",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "db:generate": "pnpm --filter @safa/api db:generate",
    "db:migrate": "pnpm --filter @safa/api db:migrate",
    "db:studio": "pnpm --filter @safa/api db:studio"
  }
}
